# bestaietsy.com — Environment Variables
# Copy this file to .env.local for local dev: cp .env.example .env.local
#
# === Resend (email service) ===
# Get from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Create an audience in Resend dashboard → Settings → Audiences
# The Audience ID looks like: 12345abc-6789-def0-1234-56789abcdef0
RESEND_AUDIENCE_ID=

# Sender email (must be verified in Resend dashboard)
# Recommended: use a subdomain like hello@mg.bestaietsy.com
RESEND_FROM_EMAIL=bestaietsy <hello@bestaietsy.com>

# === Site URLs ===
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# === Broadcast API (used by GitHub Action) ===
# Generate a long random string: openssl rand -base64 32
BROADCAST_API_SECRET=

# === Analytics (optional) ===
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GSC_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# Local development notes:
# - Without RESEND_API_KEY set, /api/subscribe returns 500
#   (you can still browse the site, just can't actually subscribe)
# - The dev server runs on http://localhost:3000 by default
# ============================================================