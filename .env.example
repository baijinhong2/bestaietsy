# bestaietsy.com — Environment Variables
# Copy this file to .env.local for local dev: cp .env.example .env.local
#
# NEVER commit .env.local to git. It's in .gitignore by default.

# === Site URLs ===
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# === Alibaba Cloud DirectMail (ap-southeast-1, Singapore) ===
# Get AccessKey from: 阿里云控制台 → RAM 访问控制 → 用户 → 创建 AccessKey
# Required RAM permissions: dm:SendMail, dm:Query*, dm:CreateMailAddress
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_DM_REGION=ap-southeast-1

# Sender addresses — each must be SEPARATELY VERIFIED in the
# DirectMail console: 邮件推送 → 发信地址 → 新建发信地址
#   - console: https://dm.ap-southeast-1.aliyuncs.com/
#   - verification: DirectMail sends a confirmation email; reply to it
ALIYUN_DM_FROM_NEWSLETTER=newsletter@bestaietsy.com   # weekly digest + welcome-weekly
ALIYUN_DM_FROM_IMPORTANT=important@bestaietsy.com      # breaking news + welcome-breaking
ALIYUN_DM_REPLY_TO=support@bestaietsy.com              # all replies route here

# Display name (optional — defaults to "bestaietsy Weekly" / "bestaietsy Breaking News")
# ALIYUN_DM_FROM_NAME=bestaietsy

# === Supabase (subscriber storage) ===
# SHARED PROJECT with drawspark (and possibly other projects).
# Use the SAME Supabase URL + keys as drawspark. Tables are namespaced
# with the `bestaietsy_` prefix (see supabase/schema.sql) so they don't
# collide with drawspark's tables.
#
# Where to get these:
#   1. Open drawspark/.env.local → copy NEXT_PUBLIC_SUPABASE_URL → paste here
#   2. Same file → copy NEXT_PUBLIC_SUPABASE_ANON_KEY → paste here
#   3. Supabase Dashboard → Settings → API → service_role key (NOT anon, NOT the
#      JWT in drawspark's Prisma DATABASE_URL). service_role bypasses RLS.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === Broadcast API (used by GitHub Actions for weekly-digest + broadcast) ===
# Generate a long random string: openssl rand -base64 32
BROADCAST_API_SECRET=

# === Analytics (optional) ===
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GSC_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# Local development notes:
# - Without ALIYUN_ACCESS_KEY_ID + SUPABASE_URL set, /api/subscribe
#   returns 500 (you can still browse the site, just can't subscribe).
# - Without BROADCAST_API_SECRET set, /api/weekly-digest + /api/broadcast
#   return 500 (can't trigger broadcasts locally).
# - Schema setup: run supabase/schema.sql in Supabase SQL Editor (one-time).
# ============================================================